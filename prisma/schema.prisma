// Configuración de conexión para PostgreSQL (Neon)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// --- Enums Técnicos ---
enum Role {
  SUPER_ADMIN
  ADMIN
  SOPORTE
  DESARROLLO
  VENTAS
  CONTACTO_CLIENTE
}

// --- Modelos de Identidad ---

model ProviderCompany {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)
  
  users      User[]   
  clients    ClientCompany[] 
  tickets    Ticket[]
  
  // Maestros dinámicos por proveedor
  statuses   TicketStatus[]
  priorities TicketPriority[]
  categories TicketCategory[]
}

model ClientCompany {
  id         String   @id @default(cuid())
  name       String
  createdAt  DateTime @default(now())
  isActive   Boolean  @default(true)
  
  providerId String
  provider   ProviderCompany @relation(fields: [providerId], references: [id])
  
  contacts   User[]           
  tickets    Ticket[]
}

model User {
  id         String   @id @default(cuid())
  name       String?
  email      String   @unique
  password   String
  role       Role     @default(CONTACTO_CLIENTE)
  createdAt  DateTime @default(now())
  isActive   Boolean  @default(true)

  providerId String?
  provider   ProviderCompany? @relation(fields: [providerId], references: [id])
  
  clientId   String?
  client     ClientCompany?   @relation(fields: [clientId], references: [id])

  assignedTickets        Ticket[]        @relation("AssignedUser")
  assignedTicketsHistory TicketHistory[] @relation("AssignedUserHistory")
  createdTickets         Ticket[]        @relation("CreatorUser")
  registeredTickets      Ticket[]        @relation("TicketRegistrar")
  historyEntries         TicketHistory[]
}

// --- Modelos Maestros (Ex-Enums) ---

model TicketStatus {
  id         String   @id @default(cuid())
  name       String   
  systemKey  String
  color      String   @default("#64748b") 
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  
  providerId String
  provider   ProviderCompany @relation(fields: [providerId], references: [id])
  
  tickets    Ticket[]
  history    TicketHistory[]
  @@unique([providerId, systemKey])
}

model TicketPriority {
  id         String   @id @default(cuid())
  name       String   
  systemKey  String
  color      String   @default("#64748b")
  weight     Int      @default(0)
  isActive   Boolean  @default(true)
  
  providerId String
  provider   ProviderCompany @relation(fields: [providerId], references: [id])
  
  tickets    Ticket[]
  history    TicketHistory[]
  @@unique([providerId, systemKey])
}

model TicketCategory {
  id         String   @id @default(cuid())
  name       String   
  prefix     String   
  isActive   Boolean  @default(true)
  
  providerId String
  provider   ProviderCompany @relation(fields: [providerId], references: [id])
  
  tickets    Ticket[]
  history    TicketHistory[]
  sequences  TicketSequence[]
}

// --- Negocio (Tickets) ---

model Ticket {
  id          String   @id @default(cuid())
  folio       String   @unique
  sequence    Int
  title       String
  description String
  
  statusId    String
  status      TicketStatus @relation(fields: [statusId], references: [id])
  
  priorityId  String
  priority    TicketPriority @relation(fields: [priorityId], references: [id])
  
  categoryId  String
  category    TicketCategory @relation(fields: [categoryId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providerId  String
  provider    ProviderCompany @relation(fields: [providerId], references: [id])

  clientId    String
  client      ClientCompany   @relation(fields: [clientId], references: [id])

  creatorId   String
  creator     User            @relation("CreatorUser", fields: [creatorId], references: [id])

  createdById String
  createdBy   User            @relation("TicketRegistrar", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?          @relation("AssignedUser", fields: [assignedToId], references: [id])

  attachments Json?
  history     TicketHistory[]
}

model TicketSequence {
  id         String   @id @default(cuid())
  categoryId String
  category   TicketCategory @relation(fields: [categoryId], references: [id])
  nextVal    Int      @default(1)
}

model TicketHistory {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  
  userId      String   
  user        User     @relation(fields: [userId], references: [id])
  
  statusId    String
  status      TicketStatus @relation(fields: [statusId], references: [id])
  
  comment     String?  @db.Text
  attachments Json?    
  isInternal  Boolean  @default(false)

  assignedToId String?  
  assignedTo   User?   @relation("AssignedUserHistory", fields: [assignedToId], references: [id])
  
  priorityId   String?
  priority     TicketPriority? @relation(fields: [priorityId], references: [id])
  
  categoryId   String?
  category     TicketCategory? @relation(fields: [categoryId], references: [id])
}